<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Inventario Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh;">

    <h2 class="title-brand">Inventario Pro Selenium</h2>

    <main class="glass-card" style="width: 100%; max-width: 400px;">
        <h2 style="text-align: center; margin-bottom: 20px; color: var(--text-main);">Iniciar Sesión</h2>
        
        <% if (error) { %>
            <p id="error-login" style="color: var(--danger); text-align: center; font-weight: bold; margin-bottom: 15px;"><%= error %></p>
        <% } %>
        
        <form action="/login" method="POST">
            <div class="form-group">
                <input type="email" name="email" id="login-email" placeholder="Correo electrónico" required>
            </div>
            <div class="form-group">
                <input type="password" name="password" id="login-password" placeholder="Contraseña" required>
            </div>
            <button type="submit" id="btn-login" class="btn-primary" style="margin-top: 10px;">Entrar al Sistema</button>
        </form>
        
        <p style="text-align: center; margin-top: 15px; font-size: 14px;">
            ¿No tienes cuenta? <a href="/register" style="color: var(--primary); font-weight: bold; text-decoration: none;">Regístrate aquí</a>
        </p>
    </main>

</body>
</html>