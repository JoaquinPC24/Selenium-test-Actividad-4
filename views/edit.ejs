<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Producto </title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="align-items: center;">

    <main class="glass-card" style="width: 100%; max-width: 400px;">
        <h2 style="text-align: center; margin-bottom: 20px;">Editar Producto</h2>
        
        <form action="/edit-product/<%= product.id %>" method="POST">
            <div class="form-group">
                <label style="font-size: 12px; color: var(--text-muted); font-weight: bold; text-transform: uppercase;">Nombre del Producto</label>
                <input type="text" id="edit-nombre" name="nombre" value="<%= product.nombre %>" required>
            </div>
            
            <div class="form-group">
                <label style="font-size: 12px; color: var(--text-muted); font-weight: bold; text-transform: uppercase;">Cantidad en Stock</label>
                <input type="number" id="edit-cantidad" name="cantidad" value="<%= product.cantidad %>" required>
            </div>
            
            <div class="form-group">
                <label style="font-size: 12px; color: var(--text-muted); font-weight: bold; text-transform: uppercase;">Precio unitario</label>
                <input type="number" id="edit-precio" name="precio" value="<%= product.precio %>" step="0.01" required>
            </div>
            
            <button type="submit" id="btn-save-edit" class="btn-primary" style="margin-top: 15px;">Guardar Cambios</button>
        </form>
        
        <div style="text-align: center; margin-top: 15px;">
            <a href="/dashboard" style="color: var(--danger); font-weight: bold; text-decoration: none; font-size: 14px;">Cancelar y volver</a>
        </div>
    </main>

</body>
</html>