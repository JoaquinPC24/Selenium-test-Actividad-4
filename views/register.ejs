<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - Inventario Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh;">
    
    <h2 class="title-brand">Inventario Pro Selenium</h2>

    <main class="glass-card" style="width: 100%; max-width: 400px;">
        <h2 style="text-align: center; margin-bottom: 20px; color: var(--text-main);">Crear Cuenta</h2>
        
        <% if (error) { %>
            <p id="error-message" style="color: var(--danger); text-align: center; font-weight: bold; margin-bottom: 15px;"><%= error %></p>
        <% } %>
        
        <form action="/register" method="POST">
            <div class="form-group">
                <input type="text" name="username" id="username" placeholder="Nombre de usuario" required>
            </div>
            <div class="form-group">
                <input type="email" name="email" id="email" placeholder="Correo electrónico" required>
            </div>
            <div class="form-group">
                <input type="password" name="password" id="password" placeholder="Contraseña (mín. 8 caracteres)" required>
            </div>
            <button type="submit" id="btn-register" class="btn-primary" style="margin-top: 10px;">Registrarme</button>
        </form>
        
        <p style="text-align: center; margin-top: 15px; font-size: 14px;">
            ¿Ya tienes cuenta? <a href="/login" style="color: var(--primary); font-weight: bold; text-decoration: none;">Inicia sesión</a>
        </p>
    </main>

</body>
</html>